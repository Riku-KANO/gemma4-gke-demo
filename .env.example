# GCP project settings
PROJECT_ID=your-gcp-project
REGION=asia-northeast1
ZONE=asia-northeast1-a
CLUSTER_NAME=gemma-demo
NODE_POOL_NAME=gpu-pool
AR_REPO=gemma-demo

# Hugging Face
# Create a token at https://huggingface.co/settings/tokens and accept the
# Gemma license on the model page before running the demo.
HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Gemma model
# IMPORTANT: verify the exact repo name on https://huggingface.co/google
# The value below is a placeholder based on the Gemma 2/3 naming pattern.
MODEL_ID=google/gemma-4-4b-it

# Agent image tag
AGENT_IMAGE_TAG=v1
