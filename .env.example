# GCP project settings
PROJECT_ID=your-gcp-project
REGION=asia-northeast1
ZONE=asia-northeast1-a
CLUSTER_NAME=gemma-demo
NODE_POOL_NAME=gpu-pool
AR_REPO=gemma-demo

# Hugging Face
# Create a token at https://huggingface.co/settings/tokens and accept the
# Gemma license on BOTH model pages before running the demo.
HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Gemma models — this demo runs TWO models simultaneously:
#   - SMALL: used by the ADK agent as the orchestrator (fast, cheap, 1 replica)
#   - LARGE: used only when the agent calls `consult_expert` (2 replicas, so
#            GKE Inference Gateway's prefix-cache-aware routing has something
#            meaningful to do)
#
# IMPORTANT: verify these are real repo names on https://huggingface.co/google
# The values below are placeholders based on expected Gemma 4 naming.
MODEL_ID_SMALL=google/gemma-4-1b-it
MODEL_ID_LARGE=google/gemma-4-4b-it

# Replica count for the LARGE model. Prefix-cache-aware routing only shows
# value with >= 2. Each replica consumes one L4 GPU.
LARGE_REPLICAS=2

# Agent image tag
AGENT_IMAGE_TAG=v1
